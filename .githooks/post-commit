#!/bin/bash
# Auto-push after every commit (triggers beta release via CI)

# Skip if SKIP_AUTO_PUSH is set
if [ -n "$SKIP_AUTO_PUSH" ]; then
  exit 0
fi

# Skip if we're in a rebase or merge
if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ] || [ -f ".git/MERGE_HEAD" ]; then
  exit 0
fi

# Get version from package.json
VERSION=$(node -p "require('./package.json').version" 2>/dev/null)

# Push commit (CI will handle beta versioning and publishing)
echo "🚀 Pushing to main..."
git push

echo "✅ Pushed - CI will publish beta"
echo ""
echo "To release as stable, run: npm run release"
