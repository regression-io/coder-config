#!/bin/bash
# Pre-commit hook - sync version across files if package.json changed

# Skip if we're in a rebase or merge
if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ] || [ -f ".git/MERGE_HEAD" ]; then
  exit 0
fi

# Check if package.json is staged
if git diff --cached --name-only | grep -q "^package.json$"; then
  # Sync version to other files
  npm run version:sync --silent 2>/dev/null

  # Stage version files
  git add lib/constants.js ui/package.json 2>/dev/null

  VERSION=$(node -p "require('./package.json').version" 2>/dev/null)
  echo "📦 Version synced: $VERSION"
fi
